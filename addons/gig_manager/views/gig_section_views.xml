<odoo>
    <record id="view_gig_section_list" model="ir.ui.view">
        <field name="name">gig.section.list</field>
        <field name="model">gig.section</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="musician_count"/>
            </list>
        </field>
    </record>

    <record id="view_gig_section_form" model="ir.ui.view">
        <field name="name">gig.section.form</field>
        <field name="model">gig.section</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="musician_count"/>
                    </group>
                    <field name="instrument_line_ids">
                        <list editable="bottom">
                            <field name="instrument_id"/>
                            <field name="quantity"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gig_section" model="ir.actions.act_window">
        <field name="name">Sections</field>
        <field name="res_model">gig.section</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
