<odoo>
    <record id="view_gig_instrument_list" model="ir.ui.view">
        <field name="name">gig.instrument.list</field>
        <field name="model">gig.instrument</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
        <record id="view_gig_instrument_form" model="ir.ui.view">
            <field name="name">gig.instrument.form</field>
            <field name="model">gig.instrument</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
    </record>
        <record id="action_gig_instrument" model="ir.actions.act_window">
            <field name="name">Instruments</field>
            <field name="res_model">gig.instrument</field>
            <field name="view_mode">list,form</field>
    </record>
</odoo>