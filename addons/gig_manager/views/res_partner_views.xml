<odoo>
    <record id="view_partner_form_gig_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.gig.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Music" name="gig_music">
                    <group string="Instruments Played">
                        <field name="instrument_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="instrument_id"/>
                                <field name="level"/>
                            </list>
                        </field>
                    </group>
                    <!-- readonly here on purpose: this is the same pivot table as
                         gig.project.participant_ids (see res_partner.py), so editing
                         it from both sides would just be two divergent paths to the
                         same data. This tab is for *seeing* which projects a contact
                         is on; adding/removing participants happens on the project's
                         own "Participants" tab. -->
                    <group string="Projects">
                        <field name="gig_project_ids" nolabel="1" widget="many2many_tags" readonly="1"/>
                    </group>
                </page>
                <page string="Rehearsal Attendance" name="gig_attendance">
                    <field name="gig_attendance_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="event_id"/>
                            <field name="status"/>
                            <field name="comment"/>
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>
</odoo>