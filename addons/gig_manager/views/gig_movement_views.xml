<odoo>
    <record id="view_gig_movement_list" model="ir.ui.view">
        <field name="name">gig.movement.list</field>
        <field name="model">gig.movement</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
    <record id="view_gig_movement_form" model="ir.ui.view">
        <field name="name">gig.movement.form</field>
        <field name="model">gig.movement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_gig_movement" model="ir.actions.act_window">
        <field name="name">Artistic Movements</field>
        <field name="res_model">gig.movement</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>