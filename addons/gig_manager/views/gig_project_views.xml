<odoo>
    <record id="view_gig_project_list" model="ir.ui.view">
        <field name="name">gig.project.list</field>
        <field name="model">gig.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <record id="view_gig_project_form" model="ir.ui.view">
        <field name="name">gig.project.form</field>
        <field name="model">gig.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <notebook>
                        <page string="Gigs">
                            <field name="gig_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="event_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gig_project" model="ir.actions.act_window">
        <field name="name">Tours</field>
        <field name="res_model">gig.project</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_gig_root" name="Gig Manager"/>
    <menuitem id="menu_gig_project" name="Tours"
              parent="menu_gig_root" action="action_gig_project" sequence="10"/>
</odoo>