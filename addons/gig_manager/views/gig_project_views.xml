<odoo>
    <record id="view_gig_project_list" model="ir.ui.view">
        <field name="name">gig.project.list</field>
        <field name="model">gig.project</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <record id="view_gig_project_form" model="ir.ui.view">
        <field name="name">gig.project.form</field>
        <field name="model">gig.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <!-- Complements, doesn't duplicate, the "Attendance" notebook page
                         below: this button opens the standalone gig.attendance list
                         (grouped by event, with Present/Absent/Uncertain filters) for a
                         richer cross-event view, while the notebook page is for quick
                         inline edits without leaving this form. -->
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_attendance"
                                class="oe_stat_button" icon="fa-users">
                            <field name="attendance_count" widget="statinfo" string="Attendance"/>
                        </button>
                        <button type="object" name="action_view_registrations"
                                class="oe_stat_button" icon="fa-inbox">
                            <field name="pending_registration_count" widget="statinfo"
                                   string="Pending Reg."/>
                        </button>
                        <!-- act_url buttons: quick access to what the public /
                             the participants actually see, in a new browser tab. -->
                        <button type="object" name="action_open_registration_page"
                                class="oe_stat_button" icon="fa-globe"
                                string="Reg. Page"/>
                        <button type="object" name="action_open_callsheet_page"
                                class="oe_stat_button" icon="fa-file-text-o"
                                string="Callsheet"/>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="section_group_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <notebook>
                        <page string="Events" name="events">
                            <field name="gig_ids">
                                <list editable="bottom">
                                    <field name="event_type"/>
                                    <field name="name"/>
                                    <field name="event_date"/>
                                    <field name="start_time" widget="float_time"/>
                                    <field name="end_time" widget="float_time"/>
                                    <field name="location"/>
                                </list>
                            </field>
                        </page>
                        <page string="Programme" name="programme">
                            <field name="piece_ids" widget="many2many_tags"/>
                        </page>
                        <!-- Registration rows (gig.project.participant), not bare
                             partner tags: every musician must be registered in a
                             section. The domain keeps the dropdown to sections that
                             actually exist in this project's section group - the
                             model-level constraint enforces the same rule for
                             writes that bypass this form. -->
                        <page string="Participants" name="participants">
                            <field name="participant_ids">
                                <list editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="section_id"
                                           domain="[('group_line_ids.group_id', '=', parent.section_group_id)]"/>
                                </list>
                            </field>
                        </page>
                        <!-- gig.attendance.project_id is a related/store field derived
                             from event_id.project_id, not a directly-settable one - so
                             the domain below is what actually stops a user from picking
                             an event that belongs to a different project. Without it,
                             a new row here could silently end up filed under that other
                             project once event_id is saved. -->
                        <page string="Attendance" name="attendance">
                            <field name="attendance_ids">
                                <list editable="bottom">
                                    <field name="event_id" domain="[('project_id', '=', parent.id)]"/>
                                    <field name="partner_id"/>
                                    <field name="status"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                        <!-- decoration-info marks the *shared* blocks (shown on both
                             public pages from the same record): the requirement is
                             that the editor makes them recognizable, and the two
                             checkbox columns spell out the exact split.
                             open_form_view: the HTML content needs the full form
                             modal - an inline cell can't host the html editor. -->
                        <page string="Public Pages" name="public_pages">
                            <field name="page_block_ids">
                                <list editable="bottom" open_form_view="1"
                                      decoration-info="on_registration and on_callsheet">
                                    <field name="sequence" widget="handle"/>
                                    <field name="title"/>
                                    <field name="on_registration"/>
                                    <field name="on_callsheet"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="title"/>
                                        <field name="on_registration"/>
                                        <field name="on_callsheet"/>
                                    </group>
                                    <field name="content" widget="html"/>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gig_project" model="ir.actions.act_window">
        <field name="name">Tours</field>
        <field name="res_model">gig.project</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>