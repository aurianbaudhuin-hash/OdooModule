<odoo>
    <record id="view_gig_piece_type_list" model="ir.ui.view">
        <field name="name">gig.piece.type.list</field>
        <field name="model">gig.piece.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
        <record id="view_gig_piece_type_form" model="ir.ui.view">
            <field name="name">gig.piece.type.form</field>
            <field name="model">gig.piece.type</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
    </record>
    <record id="action_gig_piece_type" model="ir.actions.act_window">
        <field name="name">Piece Types</field>
        <field name="res_model">gig.piece.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>