<odoo>
    <record id="view_gig_registration_list" model="ir.ui.view">
        <field name="name">gig.registration.list</field>
        <field name="model">gig.registration</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'rejected'"
                  decoration-success="state == 'accepted'">
                <field name="project_id"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone" optional="hide"/>
                <field name="section_id"/>
                <field name="partner_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_gig_registration_form" model="ir.ui.view">
        <field name="name">gig.registration.form</field>
        <field name="model">gig.registration</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Accept stays hidden until a contact is linked: the two
                         buttons visually enforce the workflow order (resolve
                         first, then decide) that action_accept also guards
                         at the model level. -->
                    <button name="action_open_resolve_wizard" type="object"
                            string="Resolve Contact" class="btn-primary"
                            invisible="state != 'pending' or partner_id"/>
                    <button name="action_open_resolve_wizard" type="object"
                            string="Re-resolve Contact"
                            invisible="state != 'pending' or not partner_id"/>
                    <button name="action_accept" type="object" string="Accept"
                            class="btn-primary"
                            invisible="state != 'pending' or not partner_id"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Request">
                            <field name="project_id"/>
                            <field name="section_id"/>
                            <!-- readonly: partner_id may only be set through the
                                 resolve wizard, which runs the duplicate search
                                 and conflict handling - hand-picking here would
                                 bypass all of it. -->
                            <field name="partner_id" readonly="1"/>
                        </group>
                        <group string="Submitted Contact Data">
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rehearsal Availability" name="availability">
                            <field name="attendance_line_ids">
                                <list editable="bottom">
                                    <field name="event_id"
                                           domain="[('project_id', '=', parent.project_id)]"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gig_registration_search" model="ir.ui.view">
        <field name="name">gig.registration.search</field>
        <field name="model">gig.registration</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="email"/>
                <field name="project_id"/>
                <filter name="pending" string="Pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="accepted" string="Accepted"
                        domain="[('state', '=', 'accepted')]"/>
                <filter name="rejected" string="Rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_project" string="Project"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_by_section" string="Section"
                            context="{'group_by': 'section_id'}"/>
                    <filter name="group_by_state" string="Status"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gig_registration" model="ir.actions.act_window">
        <field name="name">Registrations</field>
        <field name="res_model">gig.registration</field>
        <field name="view_mode">list,form</field>
        <!-- The pending ones are the organizer's to-do list; the filter is a
             default, not a domain, so the archive stays one click away. -->
        <field name="context">{'search_default_pending': 1}</field>
    </record>
</odoo>
