<odoo>
    <record id="view_gig_event_list" model="ir.ui.view">
        <field name="name">gig.event.list</field>
        <field name="model">gig.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="event_date"/>
                <field name="project_id"/>
            </list>
        </field>
    </record>

    <record id="view_gig_event_form" model="ir.ui.view">
        <field name="name">gig.event.form</field>
        <field name="model">gig.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="event_date"/>
                        <field name="project_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gig_event" model="ir.actions.act_window">
        <field name="name">Gigs</field>
        <field name="res_model">gig.event</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_gig_event" name="Gigs"
              parent="menu_gig_root" action="action_gig_event" sequence="20"/>
</odoo>