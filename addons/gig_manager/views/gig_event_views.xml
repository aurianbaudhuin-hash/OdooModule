<odoo>
    <record id="view_gig_event_list" model="ir.ui.view">
        <field name="name">gig.event.list</field>
        <field name="model">gig.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="event_type"/>
                <field name="name"/>
                <field name="event_date"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
                <field name="location"/>
                <field name="project_id"/>
            </list>
        </field>
    </record>

    <record id="view_gig_event_form" model="ir.ui.view">
        <field name="name">gig.event.form</field>
        <field name="model">gig.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="event_type"/>
                            <!-- This invisible is UX only (hides the field once it's
                                 pointless to fill in); the actual guarantee that a
                                 rehearsal never has a name is the model-level
                                 _check_name_by_type constraint, which still fires even
                                 if a record is written through code that bypasses this
                                 view entirely. -->
                            <field name="name" invisible="event_type == 'rehearsal'"/>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="event_date"/>
                            <field name="start_time" widget="float_time"/>
                            <field name="end_time" widget="float_time"/>
                            <field name="location"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Any comment about this event..."/>
                    </group>
                    <notebook>
                        <page string="Attendance" name="attendance">
                            <field name="attendance_ids">
                                <list editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="status"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_gig_event_search" model="ir.ui.view">
        <field name="name">gig.event.search</field>
        <field name="model">gig.event</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <filter string="Concerts" name="filter_concert" domain="[('event_type', '=', 'concert')]"/>
                <filter string="Rehearsals" name="filter_rehearsal" domain="[('event_type', '=', 'rehearsal')]"/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'event_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_gig_event" model="ir.actions.act_window">
        <field name="name">Gigs</field>
        <field name="res_model">gig.event</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>