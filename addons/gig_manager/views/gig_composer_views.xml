<odoo>
    <record id="view_gig_composer_list" model="ir.ui.view">
        <field name="name">gig.composer.list</field>
        <field name="model">gig.composer</field>
        <field name="arch" type="xml">
            <list>
                <field name="full_name"/>
                <field name="birth_date"/>
                <field name="death_date"/>
                <field name="movement_id"/>
                <field name="country_id"/>
            </list>
        </field>
    </record>
    <record id="view_gig_composer_form" model="ir.ui.view">
        <field name="name">gig.composer.form</field>
        <field name="model">gig.composer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="full_name"/>
                            <field name="movement_id"/>
                            <field name="country_id"/>
                        </group>
                        <group>
                            <field name="birth_date"/>
                            <field name="death_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Pieces" name="pieces">
                            <field name="piece_ids">
                                <list>
                                    <field name="title"/>
                                    <field name="composition_year"/>
                                    <field name="piece_type_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_gig_composer" model="ir.actions.act_window">
        <field name="name">Composers</field>
        <field name="res_model">gig.composer</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>